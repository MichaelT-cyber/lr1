/*
  POST /api/logs
  Створити новий лог
*/
app.post("/api/logs", (req: Request, res: Response) => {
    const { userId, passId, action, createdAt } = req.body;

    if (!userId) {
        return sendError(res, 400, "Поле userId є обов'язковим");
    }

    if (!passId) {
        return sendError(res, 400, "Поле passId є обов'язковим");
    }

    if (!action || typeof action !== "string" || action.trim().length < 3) {
        return sendError(res, 400, "Поле action обов'язкове і має містити мінімум 3 символи");
    }

    const user = users.find((u) => u.id === Number(userId));
    if (!user) {
         return sendError(res, 400, "Користувача з таким userId не існує");
    }

    const pass = passes.find((p) => p.id === Number(passId));
    if (!pass) {
         return sendError(res, 400, "Пропуску з таким passId не існує");
    }

    const newLog: Log = {
        id: Date.now(),
        userId: Number(userId),
        passId: Number(passId),
        action: action.trim(),
        createdAt: createdAt || new Date().toISOString()
    };

    logs.push(newLog);

    res.status(201).json(newLog);
});

/*
  PUT /api/logs/:id
  Оновити лог
*/
app.put("/api/logs/:id", (req: Request, res: Response) => {
    const logId = Number(req.params.id);
    const log = logs.find((l) => l.id === logId);

    if (!log) {
        return sendError(res, 404, "Лог не знайдено");
    }

    if (req.body.userId !== undefined) {
        const user = users.find((u) => u.id === Number(req.body.userId));

        if (!user) {
            return sendError(res, 400, "Користувача з таким userId не існує");
        }

        log.userId = Number(req.body.userId);
    }

    if (req.body.passId !== undefined) {
        const pass = passes.find((p) => p.id === Number(req.body.passId));

        if (!pass) {
            return sendError(res, 400, "Пропуску з таким passId не існує");
        }

        log.passId = Number(req.body.passId);
    }

    if (req.body.action !== undefined) {
        if (typeof req.body.action !== "string" || req.body.action.trim().length < 3) {
            return sendError(res, 400, "Поле action має містити мінімум 3 символи");
        }

        log.action = req.body.action.trim();
    }

    if (req.body.createdAt !== undefined) {
        log.createdAt = req.body.createdAt;
    }

    res.status(200).json(log);
});

/*
  DELETE /api/logs/:id
  Видалити лог
*/
app.delete("/api/logs/:id", (req: Request, res: Response) => {
    const logId = Number(req.params.id);
    const logIndex = logs.findIndex((l) => l.id === logId);

    if (logIndex === -1) {
        return sendError(res, 404, "Лог не знайдено");
    }

    logs.splice(logIndex, 1);

    res.status(204).send();
});

/*
  GET /api/passes
  Отримати список усіх пропусків
  Підтримує:
  - фільтрацію: /api/passes?status=active
  - пагінацію: /api/passes?limit=5&offset=0
*/
app.get("/api/passes", (req: Request, res: Response) => {
    let result = [...passes];

    const { status, limit, offset } = req.query;

    if (status !== undefined) {
        result = result.filter((p) => p.status === String(status));
    }

    const limitNumber = Number(limit) || 10;
    const offsetNumber = Number(offset) || 0;

    return sendList(res, result, limitNumber, offsetNumber);
});

/*
  GET /api/passes/:id
  Отримати один пропуск за id
*/
app.get("/api/passes/:id", (req: Request, res: Response) => {
    const id = Number(req.params.id);
    const pass = passes.find((p) => p.id === id);

    if (!pass) {
        return sendError(res, 404, "Пропуск не знайдено");
    }

    res.status(200).json(pass);
});

/*
  POST /api/passes
  Створити новий пропуск
*/
app.post("/api/passes", (req: Request, res: Response) => {
    const { userId, validFrom, validTo, status } = req.body;

    if (!userId) {
        return sendError(res, 400, "Поле userId є обов'язковим");
    }

    const user = users.find((u) => u.id === Number(userId));

    if (!user) {
         return sendError(res, 400, "Користувача з таким userId не існує");
    }

    if (!validFrom || !validTo) {
        return sendError(res, 400, "Поля validFrom та validTo є обов'язковими");
    }

    const newPass: Pass = {
        id: Date.now(),
        userId: Number(userId),
        validFrom,
        validTo,
        status: status || "active"
    };

    passes.push(newPass);

    res.status(201).json(newPass);
});

/*
  PUT /api/passes/:id
  Оновити пропуск
*/
app.put("/api/passes/:id", (req: Request, res: Response) => {
    const id = Number(req.params.id);
    const pass = passes.find((p) => p.id === id);

    if (!pass) {
        return sendError(res, 404, "Пропуск не знайдено");
    }

    if (req.body.userId !== undefined) {
        const user = users.find((u) => u.id === Number(req.body.userId));

        if (!user) {
            return sendError(res, 400, "Користувача з таким userId не існує");
        }

        pass.userId = Number(req.body.userId);
    }

    pass.validFrom = req.body.validFrom ?? pass.validFrom;
    pass.validTo = req.body.validTo ?? pass.validTo;
    pass.status = req.body.status ?? pass.status;

    res.status(200).json(pass);
});

app.delete("/api/passes/:id", (req: Request, res: Response) => {
    const id = Number(req.params.id);
    const index = passes.findIndex((p) => p.id === id);

    if (index === -1) {
        return sendError(res, 404, "Пропуск не знайдено");
    }

    passes.splice(index, 1);

    res.status(204).send();
});

/*
  POST /api/form-submit
  Маршрут для отримання даних з фронтенд-форми
*/
app.post("/api/form-submit", (req: Request, res: Response) => {

    const { userName, reason } = req.body;

    if (!userName || userName.trim().length < 2) {
        return sendError(res, 400, "Ім'я повинно містити мінімум 2 символи");
    }

    if (!reason) {
        return sendError(res, 400, "Причина є обов'язковою");
    }

    res.status(201).json({
        message: "Дані форми отримано",
        data: {
            userName,
            reason
        }
    });

});

