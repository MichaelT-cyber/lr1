import express, { Request, Response, NextFunction } from "express";
import cors from "cors"

const app = express();
app.use(cors());
const PORT = 3000;

app.use(express.json());

/*
  Middleware логування запитів.
  Логує: метод, шлях, статус відповіді і час виконання.
*/
app.use((req: Request, res: Response, next: NextFunction) => {
    const start = Date.now();

    res.on("finish", () => {
        const timeMs = Date.now() - start;
        console.log(`${req.method} ${req.originalUrl} -> ${res.statusCode} (${timeMs}ms)`);
    });

    next();
});

/*
  Типи сутностей
*/
type User = {
    id: number;
    fullName: string;
    role: string;
    isActive: boolean;
};

type Reason = {
    id: number;
    title: string;
    description: string;
};

type Pass = {
    id: number;
    userId: number;
    validFrom: string;
    validTo: string;
    status: string;
};

type Log = {
    id: number;
    userId: number;
    passId: number;
    action: string;
    createdAt: string;
};

/*
  Тимчасове сховище даних у пам'яті.
*/
const users: User[] = [];
const passes: Pass[] = [];
const reasons: Reason[] = [];
const logs: Log[] = [];

type ErrorResponse = {
    error: {
        message: string;
        status: number;
    };
};

type ListResponse<T> = {
    total: number;
    limit: number;
    offset: number;
    data: T[];
};

function sendError(res: Response, status: number, message: string) {
    return res.status(status).json({
        error: {
            message,
            status
        }
    } as ErrorResponse);
}

function sendList<T>(res: Response, items: T[], limit: number, offset: number) {
    return res.status(200).json({
        total: items.length,
        limit,
        offset,
        data: items.slice(offset, offset + limit)
    } as ListResponse<T>);
}

/*
  Тестовий маршрут
*/
app.get("/", (req: Request, res: Response) => {
    res.json({ message: "Server працює на TypeScript" });
});

/*
  GET /api/users
  Отримати список усіх користувачів
  Підтримує:
  - фільтрацію: /api/users?isActive=true
  - пагінацію: /api/users?limit=5&offset=0
*/
app.get("/api/users", (req: Request, res: Response) => {
    let result = [...users];

    const { isActive, limit, offset } = req.query;

    if (isActive !== undefined) {
        const isActiveBool = String(isActive) === "true";
        result = result.filter((u) => u.isActive === isActiveBool);
    }

    const limitNumber = Number(limit) || 10;
    const offsetNumber = Number(offset) || 0;

    return sendList(res, result, limitNumber, offsetNumber);
});

/*
  GET /api/users/:id
  Отримати одного користувача за id
*/
app.get("/api/users/:id", (req: Request, res: Response) => {
    const userId = Number(req.params.id);
    const user = users.find((u) => u.id === userId);

    if (!user) {
        return sendError(res, 404, "Користувача не знайдено");
    }

    res.status(200).json(user);
});

/*
  POST /api/users
  Створити нового користувача
*/
app.post("/api/users", (req: Request, res: Response) => {
    const { fullName, role, isActive } = req.body;

    if (!fullName || typeof fullName !== "string" || fullName.trim().length < 2) {
       return sendError(res, 400, "Поле fullName обов'язкове і має містити мінімум 2 символи");
    }

    if (!role || typeof role !== "string" || role.trim().length < 2) {
        return sendError(res, 400, "Поле role обов'язкове і має містити мінімум 2 символи");
    }

    const newUser: User = {
        id: Date.now(),
        fullName: fullName.trim(),
        role: role.trim(),
        isActive: typeof isActive === "boolean" ? isActive : true
    };

    users.push(newUser);

    res.status(201).json(newUser);
});

/*
  PUT /api/users/:id
  Оновити користувача
*/
app.put("/api/users/:id", (req: Request, res: Response) => {
    const userId = Number(req.params.id);
    const { fullName, role, isActive } = req.body;

    const userIndex = users.findIndex((u) => u.id === userId);

    if (userIndex === -1) {
        return sendError(res, 404, "Користувача не знайдено");
    }

    if (!fullName || typeof fullName !== "string" || fullName.trim().length < 2) {
        return sendError(res, 400, "Поле fullName обов'язкове і має містити мінімум 2 символи");
    }

    if (!role || typeof role !== "string" || role.trim().length < 2) {
        return sendError(res, 400, "Поле role обов'язкове і має містити мінімум 2 символи");
    }

    users[userIndex] = {
        ...users[userIndex],
        fullName: fullName.trim(),
        role: role.trim(),
        isActive: typeof isActive === "boolean" ? isActive : users[userIndex].isActive
    };

    res.status(200).json(users[userIndex]);
});

/*
  DELETE /api/users/:id
  Видалити користувача
*/
app.delete("/api/users/:id", (req: Request, res: Response) => {
    const userId = Number(req.params.id);
    const userIndex = users.findIndex((u) => u.id === userId);

    if (userIndex === -1) {
        return sendError(res, 404, "Користувача не знайдено");
    }

    users.splice(userIndex, 1);

    res.status(204).send();
});

