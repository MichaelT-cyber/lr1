/*
  POST /api/passes
  Створити новий пропуск
*/
app.post("/api/passes", (req, res) => {
    const { userId, validFrom, validTo, status } = req.body;

    // перевіряємо, чи переданий userId
    if (!userId) {
        return res.status(400).json({ message: "Поле userId є обов'язковим" });
    }

    // перевіряємо, чи існує користувач з таким id
    const user = users.find((u) => u.id === Number(userId));

    if (!user) {
        return res.status(400).json({ message: "Користувача з таким userId не існує" });
    }

    // перевіряємо обов'язкові поля дат
    if (!validFrom || !validTo) {
        return res.status(400).json({ message: "Поля validFrom та validTo є обов'язковими" });
    }

    const newPass = {
        id: Date.now(),
        userId: Number(userId),
        validFrom,
        validTo,
        status: status || "active"
    };

    passes.push(newPass);

    res.status(201).json(newPass);
});

/*
  PUT /api/passes/:id
  Оновити пропуск
*/
app.put("/api/passes/:id", (req, res) => {
    const id = Number(req.params.id);

    const pass = passes.find((p) => p.id === id);

    if (!pass) {
        return res.status(404).json({ message: "Пропуск не знайдено" });
    }

    // якщо передали userId, перевіряємо чи такий user існує
    if (req.body.userId !== undefined) {
        const user = users.find((u) => u.id === Number(req.body.userId));

        if (!user) {
            return res.status(400).json({ message: "Користувача з цим userId не існує" });
        }

        pass.userId = Number(req.body.userId);
    }

    // оновлюємо поля, якщо вони передані
    pass.validFrom = req.body.validFrom ?? pass.validFrom;
    pass.validTo = req.body.validTo ?? pass.validTo;
    pass.status = req.body.status ?? pass.status;

    res.status(200).json(pass);
});

/*
  DELETE /api/passes/:id
  Видалити пропуск
*/
app.delete("/api/passes/:id", (req, res) => {
    const id = Number(req.params.id);

    const index = passes.findIndex((p) => p.id === id);

    if (index === -1) {
        return res.status(404).json({ message: "Пропуск не знайдено" });
    }

    passes.splice(index, 1);

    res.status(204).send();
});

