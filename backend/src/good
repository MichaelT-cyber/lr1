// підключаємо express
const express = require("express");

// створюємо сервер
const app = express();

// порт сервера
const PORT = 3000;

// дозволяємо читати JSON
app.use(express.json());

/*
  Middleware логування запитів.
  Логує: метод, шлях, статус відповіді і час виконання.
*/
app.use((req, res, next) => {
    const start = Date.now();

    // коли відповідь завершиться — виводимо лог
    res.on("finish", () => {
        const timeMs = Date.now() - start;
        console.log(`${req.method} ${req.originalUrl} -> ${res.statusCode} (${timeMs}ms)`);
    });

    next(); // передаємо керування далі до маршрутів
});

