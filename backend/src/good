/*
  POST /api/logs
  Створити новий лог
*/
app.post("/api/logs", (req, res) => {
    // дістаємо поля з body запиту
    const { userId, passId, action, createdAt } = req.body;

    // перевіряємо userId
    if (!userId) {
        return res.status(400).json({ message: "Поле userId є обов'язковим" });
    }

    // перевіряємо passId
    if (!passId) {
        return res.status(400).json({ message: "Поле passId є обов'язковим" });
    }

    // перевіряємо action
    if (!action || typeof action !== "string" || action.trim().length < 3) {
        return res.status(400).json({
            message: "Поле action обов'язкове і має містити мінімум 3 символи"
        });
    }

    // перевіряємо, чи існує користувач
    const user = users.find((u) => u.id === Number(userId));
    if (!user) {
        return res.status(400).json({ message: "Користувача з таким userId не існує" });
    }

    // перевіряємо, чи існує пропуск
    const pass = passes.find((p) => p.id === Number(passId));
    if (!pass) {
        return res.status(400).json({ message: "Пропуску з таким passId не існує" });
    }

    // створюємо новий лог
    const newLog = {
        id: Date.now(),
        userId: Number(userId),
        passId: Number(passId),
        action: action.trim(),
        createdAt: createdAt || new Date().toISOString()
    };

    // додаємо лог у масив
    logs.push(newLog);

    // повертаємо створений лог
    res.status(201).json(newLog);
});

/*
  PUT /api/logs/:id
  Оновити лог
*/
app.put("/api/logs/:id", (req, res) => {
    // беремо id логу з URL
    const logId = Number(req.params.id);

    // шукаємо лог у масиві
    const log = logs.find((l) => l.id === logId);

    // якщо лог не знайдено — повертаємо 404
    if (!log) {
        return res.status(404).json({ message: "Лог не знайдено" });
    }

    // якщо передали userId — перевіряємо, чи існує користувач
    if (req.body.userId !== undefined) {
        const user = users.find((u) => u.id === Number(req.body.userId));

        if (!user) {
            return res.status(400).json({ message: "Користувача з таким userId не існує" });
        }

        log.userId = Number(req.body.userId);
    }

    // якщо передали passId — перевіряємо, чи існує пропуск
    if (req.body.passId !== undefined) {
        const pass = passes.find((p) => p.id === Number(req.body.passId));

        if (!pass) {
            return res.status(400).json({ message: "Пропуску з таким passId не існує" });
        }

        log.passId = Number(req.body.passId);
    }

    // якщо передали action — перевіряємо його
    if (req.body.action !== undefined) {
        if (typeof req.body.action !== "string" || req.body.action.trim().length < 3) {
            return res.status(400).json({
                message: "Поле action має містити мінімум 3 символи"
            });
        }

        log.action = req.body.action.trim();
    }

    // якщо передали createdAt — оновлюємо його
    if (req.body.createdAt !== undefined) {
        log.createdAt = req.body.createdAt;
    }

    // повертаємо оновлений лог
    res.status(200).json(log);
});

